<?xml version="1.0" encoding="utf-8"?>
<!--
Ginger manipuland for the OpenArm pick-and-place demo.

Source: 3D scan from https://github.com/alexhegit/Scan2Sim (assets/ginger),
converted to a MuJoCo asset by Scan2Sim (centered, mm->m). The visual mesh here
is decimated to ~14k faces (vs ~148k original) to keep the repo small and make
software (osmesa) rendering fast; collision is the convex hull. No texture is
shipped - an rgba tint approximates the ginger color.
-->
<mujoco model="ginger">
  <compiler angle="radian" meshdir="meshes" autolimits="true"/>
  <asset>
    <mesh name="visual_mesh" file="visual.obj"/>
    <mesh name="collision_mesh" file="collision.stl"/>
  </asset>
  <worldbody>
    <body name="ginger" pos="0 0 0.080">
      <freejoint/>
      <inertial pos="-0.00162693 -0.00028175 0.00061394" mass="0.057462" diaginertia="0.00001626 0.00002307 0.00001699"/>
      <geom name="visual" type="mesh" mesh="visual_mesh" rgba="0.78 0.6 0.32 1" contype="0" conaffinity="0" group="0"/>
      <geom name="collision" type="mesh" mesh="collision_mesh" group="3"/>
    </body>
  </worldbody>
</mujoco>
